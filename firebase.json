{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        ".env*"
      ]
    }
  ],
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "README.md",
      "functions/**",
      "netlify.toml",
      "netlify/**",
      "supabase/**",
      "coverage/**",
      "dist/**"
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          }
        ]
      },
      {
        "source": "/assets/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "/Photos/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/subscribe",
        "function": {
          "functionId": "subscribe",
          "region": "europe-west1"
        }
      },
      {
        "source": "/api/contact",
        "function": {
          "functionId": "contact",
          "region": "europe-west1"
        }
      },
      {
        "source": "/api/events",
        "function": {
          "functionId": "events",
          "region": "europe-west1"
        }
      }
    ]
  }
}
